# ============================================================
# Co-Scientist Agent 환경 설정 템플릿
# 폐쇄망 서버 이전 시 이 파일을 .env로 복사 후 값을 변경하세요.
# ============================================================

# --- MariaDB ---
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=your-password
MARIADB_DATABASE=paper
# MARIADB_URL=mysql+pymysql://user:password@localhost:3306/paper

# --- Milvus ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DATABASE=m_paper
MILVUS_COLLECTION=m_sid_v_09_01

# --- LLM (OpenAI-compatible API) ---
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=your-api-key
LLM_MODEL=qwen3-235B-A22B-Instruct-2507

# --- Embedding (OpenAI-compatible API) ---
EMBEDDING_BASE_URL=http://localhost:8080/v1
EMBEDDING_API_KEY=your-api-key
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# --- Langfuse ---
LANGFUSE_SECRET_KEY=your-secret-key
LANGFUSE_PUBLIC_KEY=your-public-key
LANGFUSE_HOST=http://localhost:3000

# --- RAG ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5
